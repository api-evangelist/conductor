{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EventHandlerAction",
  "type": "object",
  "properties": {
    "action": {
      "type": "string",
      "description": "The action type"
    },
    "start_workflow": {
      "type": "object",
